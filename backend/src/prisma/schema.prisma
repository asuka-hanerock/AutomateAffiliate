generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  createdAt DateTime  @default(now())
  accounts  Account[]
}

model Account {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName     String @default("")  // アカウント名（表示用）
  profileImageUrl String @default("")  // Xアイコン画像URL
  xUsername       String @default("")  // @ユーザー名
  bio             String @default("")  // 自己紹介
  niche     String    @default("転職")
  pronoun   String    @default("僕") // 一人称（僕、俺、私、自分、あだ名など）
  trademark String    @default("")  // トレードマーク絵文字（🐢など、任意）
  cronSchedule String @default("0 9 * * *")
  ctaEnabled Boolean  @default(false)
  skipPreview Boolean @default(false) // trueなら「今すぐ実行」でもプレビューなし
  maxCharsPerPost Int @default(140)   // 1投稿あたりの文字数上限（140=通常, 280=プレミアム等）

  // 暗号化されたAPIキー
  twitterApiKey           String @default("")
  twitterApiSecret        String @default("")
  twitterAccessToken      String @default("")
  twitterAccessTokenSecret String @default("")
  claudeApiKey            String @default("")

  // Google連携（暗号化）
  googleServiceAccountJson String @default("") // サービスアカウントJSON全体
  googleSpreadsheetUrl     String @default("") // スプレッドシートURL（IDは自動抽出）

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  postLogs  PostLog[]
  prompts   PromptTemplate[]
  trendFormats TrendFormat[]
}

model PostLog {
  id        String   @id @default(uuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  topic     String
  content   String
  tweetIds  String   @default("") // カンマ区切りのツイートID
  postedAt  DateTime @default(now())
  status    String   @default("pending") // pending, success, failed
}

model PromptTemplate {
  id        String   @id @default(uuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name      String   // 表示名（例: 「通常スレッド」「煽り系」）
  type      String   // topic_select | thread_generate
  content   String   // プロンプト本文
  scheduleType String @default("always") // always | weekdays | interval | rotation
  scheduleConfig String @default("{}") // JSON: {"days":[1,3,5]} or {"interval":3}
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0) // ローテーション順
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TrendFormat {
  id        String   @id @default(uuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name      String   // 表示名（例: 「〇〇な人の特徴」）
  template  String   // テンプレート説明（例: 「{{topic}}な人の特徴」→ 特徴を5つ挙げるスレッド）
  example   String   @default("") // 使用例（任意）
  postCount Int      @default(5)  // この構文の投稿数（2〜10）
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
